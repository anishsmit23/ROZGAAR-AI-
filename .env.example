# LLM (Groq — OpenAI-compatible API)
GROQ_API_KEY=gsk_...
# Optional override (default is Groq’s OpenAI-compatible endpoint)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Model id from https://console.groq.com/docs/models
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.2

# Search
SERPAPI_KEY=...

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# App
APP_ENV=development
LOG_LEVEL=INFO
DB_PATH=data/db/jobs.db
CHROMA_PATH=data/db/chroma
BASE_RESUME_PATH=data/resumes/base_resume.pdf
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
# URL Streamlit or other clients use to reach FastAPI (defaults work for local dev)
PUBLIC_API_URL=http://127.0.0.1:8000
# Comma-separated extra CORS origins (e.g. your Streamlit Cloud URL)
# CORS_EXTRA_ORIGINS=
# If set to 1/true, Streamlit dashboard calls FastAPI instead of in-process agents
# ROZGAAR_USE_API=0
# ROZGAAR_API_URL=http://127.0.0.1:8000
