# LLM (Groq primary, OpenAI fallback)
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk_...
# Optional override (default is Groq’s OpenAI-compatible endpoint)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Model id from https://console.groq.com/docs/models
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.2

# Search
SERPAPI_KEY=...

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Postgres
POSTGRES_USER=rozgaar
POSTGRES_PASSWORD=rozgaar
POSTGRES_DB=rozgaar
DATABASE_URL=postgresql+asyncpg://rozgaar:rozgaar@postgres:5432/rozgaar

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_URL=http://chroma:8000

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=raw-html

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth (RS256)
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_PASSWORD_SECRET=change-me
VERIFICATION_SECRET=change-me

# App
APP_ENV=development
LOG_LEVEL=INFO
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
# URL clients use to reach FastAPI (defaults work for local dev)
PUBLIC_API_URL=http://127.0.0.1:8000
# Comma-separated extra CORS origins
# CORS_EXTRA_ORIGINS=
